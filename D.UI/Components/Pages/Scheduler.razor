@page "/scheduler"
@using MudBlazor
@rendermode InteractiveServer
@namespace D.UI.Pages

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4" @onmousemove="OnMouseMove" @onmouseup="OnMouseUp">

    <MudText Typo="Typo.h5" Class="mb-4">
        MES dispatching dashboard
    </MudText>

    <MudGrid>

        <!-- ================= JOB POOL ================= -->
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-3">

                <MudText Typo="Typo.subtitle1" Class="mb-2">
                    Job Pool
                </MudText>

                @if (_jobs is null)
                {
                    <MudProgressCircular Indeterminate />
                }
                else
                {
                    @foreach (var job in _jobs)
                    {
                        <div class="job-card" @onmousedown="(e) => StartDrag(e, job)" @onclick="() => OpenJobDialog(job)">
                            <span class="job-dot @(HasAvailableMachine(job) ? "job-ok" : "job-bad")"></span>
                            <b>@job.OrderNo</b><br />
                            <small>@job.ProductName</small>
                        </div>
                    }
                }

            </MudPaper>
        </MudItem>

        <!-- ================= MACHINE BOARD ================= -->
        <MudItem xs="12" md="9">
            <MudPaper Class="pa-3">

                <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudText Typo="Typo.subtitle1">
                        Machine Schedule
                    </MudText>

                    <MudSpacer />

                    <MudDatePicker Date="_selectedDate" Label="Chọn ngày" DateChanged="OnDateChanged" Dense="true"
                                   DateFormat="dd/MM/yyyy" />
                </MudStack>

                @if (_machines is null)
                {
                    <MudProgressCircular Indeterminate />
                }
                else
                {
                    <div id="timelineScroll" class="timeline-wrapper">

                        <!-- ===== HEADER GIỜ ===== -->
                        <div id="timeHeader" class="time-header">
                            @for (int h = 0; h < 24; h++)
                            {
                                <div class="time-cell">@($"{h:00}:00")</div>
                            }
                        </div>

                        <!-- ===== MACHINE ROWS ===== -->
                        @foreach (var machine in _machines)
                        {
                            <div class="machine-row" @onmouseenter="() => _hoverMachineId = machine.Id"
                                 @onmouseleave="() => _hoverMachineId = null">

                                <div class="machine-label">
                                    <span class="status-dot @GetMachineColor(machine.Status)"></span>
                                    @machine.Name
                                </div>

                                <div class="timeline @( _hoverMachineId == machine.Id && _isDragging ? "timeline-hover" : "" )">

                                    @foreach (var task in _board.Where(x =>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               x.WorkCenterId == machine.Id &&
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               x.ScheduledStart != null &&
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             x.ScheduledEnd != null))
                                    {
                                        <div class="task-bar" style="
                                            left:@($"{GetLeftPercent(task.ScheduledStart)}%");
                                            width:@($"{GetWidthPercent(task.ScheduledStart, task.ScheduledEnd)}%");
                                            ">
                                            @task.WorkOrderNo
                                        </div>
                                    }

                                </div>
                            </div>
                        }
                    </div>
                }

            </MudPaper>
        </MudItem>

    </MudGrid>

</MudContainer>

@if (_isDragging && _draggingJob != null)
{
    <div class="drag-ghost" style="left:@(_mouseX + 10)px; top:@(_mouseY + 10)px;">
        @_draggingJob.OrderNo
    </div>
}