@page "/scheduler"
@using MudBlazor
@inject WorkOrderService WorkOrderService
@inject IDialogService DialogService
@rendermode InteractiveServer

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">

    <MudText Typo="Typo.h5" Class="mb-4">
        MES dispatching dashboard
    </MudText>

    <MudGrid>

        <MudItem xs="12" md="3">
            <MudPaper Class="pa-3">

                <MudText Typo="Typo.subtitle1" Class="mb-2">
                    Job Pool
                </MudText>

                @if (_jobs is null)
                {
                    <MudProgressCircular Indeterminate />
                }
                else
                {
                    @foreach (var job in _jobs)
                    {
                        <div class="job-card"
                             draggable="true"
                             @ondragstart="e => OnDragStart(e, job)">

                            <b>@job.OrderNo</b><br />
                            <small>@job.ProductName</small>
                        </div>
                    }
                }

            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="9">
            <MudPaper Class="pa-3">

                <MudText Typo="Typo.subtitle1" Class="mb-3">
                    Machine Schedule
                </MudText>

                @if (_machines is null)
                {
                    <MudProgressCircular Indeterminate />
                }
                else
                {
                    @foreach (var machine in _machines)
                    {
                        <div class="machine-row"
                             @ondragover="AllowDrop"
                             @ondrop="e => OnDrop(e, machine)">

                            <div class="machine-label">
                                @machine.Name
                            </div>

                            <div class="timeline">

                                @foreach (var task in _board.Where(x => x.WorkCenterId == machine.Id))
                                {
                                    <div class="task-bar">
                                        @task.WorkOrderNo
                                    </div>
                                }

                            </div>
                        </div>
                    }
                }

            </MudPaper>
        </MudItem>

    </MudGrid>

</MudContainer>

<style>

.job-card {
    border: 1px solid #ddd;
    padding: 8px;
    margin-bottom: 8px;
    border-radius: 6px;
    background: #fafafa;
    cursor: grab;
}

.machine-row {
    display: flex;
    border-bottom: 1px solid #eee;
    padding: 8px 0;
}

.machine-label {
    width: 180px;
    font-weight: 600;
}

.timeline {
    flex: 1;
    position: relative;
    min-height: 40px;
    background: #f5f5f5;
    border-radius: 6px;
}

.task-bar {
    display: inline-block;
    background: #4caf50;
    color: white;
    padding: 4px 10px;
    margin: 4px;
    border-radius: 4px;
    font-size: 12px;
}

</style>

@code {

    private List<JobItem>? _jobs;
    private List<Machine>? _machines;
    private List<DispatchTaskDto> _board = new();

    private JobItem? _draggingJob;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _jobs = await WorkOrderService.GetPendingJobsAsync();
        _machines = await WorkOrderService.GetWorkCentersAsync();
        _board = await WorkOrderService.GetBoardAsync(DateTime.Today);
    }

    private void OnDragStart(DragEventArgs e, JobItem job)
    {
        _draggingJob = job;
    }

    private void AllowDrop(DragEventArgs e)
    {
        @* e.PreventDefault(); *@
    }

    private async Task OnDrop(DragEventArgs e, Machine machine)
{
    if (_draggingJob is null)
        return;

    await WorkOrderService.AssignJobAsync(
        _draggingJob.Id,
        machine.Id,
        stepOrder: 1,
        scheduledStart: DateTime.Now);

    _draggingJob = null;

    await LoadData();
    StateHasChanged();
}
}